# Required environment variables for iOS build/upload via Fastlane.
# Copy to .env.ios (git-ignored) and fill in real values.

# Name of the provisioning profile for the main app target
IOS_PROVISIONING_PROFILE_NAME=

# Bundle ID for the Share Extension target
IOS_SHARE_BUNDLE_ID=

# Name of the provisioning profile for the Share Extension target
IOS_SHARE_PROVISIONING_PROFILE_NAME=
